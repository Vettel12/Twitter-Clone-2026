# --- Database Configuration ---
POSTGRES_DB=twitter_clone_db
POSTGRES_USER=<your_db_user>
POSTGRES_PASSWORD=<your_db_password>

# Хост БД:
# - Docker Compose: postgres
# - Kubernetes: postgres-service
# - Локально (pytest, alembic): localhost
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Security ---
# Сгенерируйте свой ключ: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=<generate_your_own_secret_key>

# --- Kafka ---
# - Docker Compose: kafka:29092
# - Kubernetes: kafka-service:29092
# - Локально: localhost:9092
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# --- Redis ---
# - Docker Compose: redis://redis:6379/0
# - Kubernetes: redis://redis-service:6379/0
# - Локально: redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# --- CORS Configuration ---
ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=GET,POST,DELETE
CORS_ALLOW_HEADERS=api-key,content-type,accept
CORS_MAX_AGE=3600

# --- Logging ---
SQLALCHEMY_ECHO=false
LOG_API_KEYS=false
