# ==============================================================================
# Twitter Clone 2026 — Конфигурация окружения (ЛОКАЛЬНАЯ РАЗРАБОТКА)
# ==============================================================================
# Инструкция:
# 1. Скопируйте этот файл: cp .env.example .env
# 2. Замените значения на свои (если нужно)
# 3. Для Docker Compose оставьте POSTGRES_HOST=postgres
# 4. Для локальных тестов (pytest) измените POSTGRES_HOST=localhost
# ==============================================================================

# --- Database Configuration ---
# Имя базы данных (создается автоматически при первом запуске)
POSTGRES_DB=twitter_clone_db

# Пользователь базы данных (НЕ superuser, обычный пользователь)
POSTGRES_USER=skillbox

# Пароль пользователя БД (в production используйте сложный пароль!)
POSTGRES_PASSWORD=skillbox_2026

# Хост БД — зависит от окружения:
# • Docker Compose:     postgres (имя сервиса в docker-compose.yml)
# • Kubernetes:         postgres-service (ClusterIP Service)
# • Локально (pytest):  localhost (если БД запущена на хосте)
POSTGRES_HOST=postgres

# Порт БД (стандартный PostgreSQL порт)
POSTGRES_PORT=5432

# --- Security ---
# Секретный ключ для подписи токенов и сессий.
# Генерация: python -c "import secrets; print(secrets.token_urlsafe(32))"
# ВНИМАНИЕ: В production ОБЯЗАТЕЛЬНО используйте уникальный ключ!
SECRET_KEY=super_secret_key_2026_do_not_share

# --- Kafka ---
# Адрес Kafka брокера:
# • Docker Compose:     kafka:29092 (внутренний listener)
# • Kubernetes:         kafka-service:29092
# • Локально без Docker: localhost:9092 (если Kafka на хосте)
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# --- Redis ---
# URL для подключения к Redis:
# • Docker Compose:     redis://redis:6379/0
# • Kubernetes:         redis://redis-service:6379/0
# • Локально:           redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# --- CORS Configuration ---
# Разрешенные origin для CORS (через запятую, без пробелов)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://twitter-clone.example.com

# Разрешить передачу credentials (cookies, authorization headers)
CORS_ALLOW_CREDENTIALS=false

# Разрешенные HTTP методы
CORS_ALLOW_METHODS=GET,POST,DELETE

# Разрешенные заголовки (через запятую, без пробелов)
CORS_ALLOW_HEADERS=api-key,content-type,accept

# Время кеширования preflight запросов (в секундах, 3600 = 1 час)
CORS_MAX_AGE=3600

# --- Logging ---
# Включить логирование SQL запросов (true/false)
# В production установите false для производительности
SQLALCHEMY_ECHO=false

# Логирование API ключей (true/false) — только для отладки!
LOG_API_KEYS=false
