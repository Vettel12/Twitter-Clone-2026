# --- Database Configuration ---
# Имя базы данных
POSTGRES_DB=twitter_clone_db
# Пользователь БД
POSTGRES_USER=skillbox
# Пароль БД (в проде использовать сложный пароль!)
POSTGRES_PASSWORD=skillbox_2026

# Хост БД:
# - Docker Compose: postgres (имя сервиса)
# - Kubernetes: postgres-service
# - Локальная разработка (pytest, alembic): localhost
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Security ---
# Секретный ключ для подписи токенов (сгенерируйте свой для продакшена)
SECRET_KEY=super_secret_key_2026_do_not_share

# --- Kafka ---
# Docker Compose: kafka:29092 (внутренний listener)
# Kubernetes: kafka-service:29092
# Локально без Docker: localhost:9092
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# --- Redis ---
# Docker Compose: redis://redis:6379/0
# Kubernetes: redis://redis-service:6379/0
# Локально: redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0