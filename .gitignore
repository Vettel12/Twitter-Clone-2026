# ============================================
# Секреты и конфигурация (НЕ ДОЛЖНЫ быть в git)
# ============================================
.env
.env.*
!.env.example

# ============================================
# Python
# ============================================
# Байт-код и кэш
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Распространяемые пакеты
*.egg
*.egg-info/
dist/
build/
*.whl
*.tar.gz

# ============================================
# Виртуальные окружения
# ============================================
venv/
.venv/
env/
ENV/
.conda/

# ============================================
# IDE и редакторы
# ============================================
# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr

# VS Code
.vscode/
*.code-workspace
!.vscode/settings.json.example
!.vscode/launch.json

# Vim / Nano
*.swp
*.swo
*~
*.un~

# ============================================
# Тестирование и покрытие
# ============================================
.pytest_cache/
pytestdebug.log
.coverage
coverage.xml
coverage.json
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# ============================================
# Логи и временные файлы
# ============================================
*.log
logs/
*.tmp
*.temp

# ============================================
# Медиафайлы (загруженные пользователями)
# ============================================
media/
media/*
!media/.gitkeep

# ============================================
# Docker (локальные артефакты)
# ============================================
.docker/
*.tar

# ============================================
# OS
# ============================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================
# Git
# ============================================
*.orig
.git-rewrite/
